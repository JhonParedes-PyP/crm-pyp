# === CRM P&P - Variables de Entorno (PLANTILLA) ===
# Copia este archivo como .env y rellena con tus valores reales.

DJANGO_SECRET_KEY=tu-clave-secreta-aqui
DJANGO_DEBUG=True

# Base de Datos PostgreSQL
DB_NAME=pyp_db
DB_USER=postgres
DB_PASSWORD=tu-contraseña-aqui
DB_HOST=localhost
DB_PORT=5432

# Zadarma (Telefonía)
ZADARMA_KEY=tu-zadarma-key
ZADARMA_SECRET=tu-zadarma-secret
ZADARMA_SIP=tu-extension-sip
ZADARMA_API_TOKEN=tu-token-webrtc
